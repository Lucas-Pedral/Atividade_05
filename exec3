#include <stdio.h>

int main(){
    int numero[10];
    int maior;
    
    for (int i = 0; i < 10; i++){
        printf("Digite os números para saber o maior entre eles ");
        scanf("%d", &numero[i]);
        
        if(numero[i] > maior){
            maior = numero[i];
        }
    }

    printf("O maior número foi \n%d", maior);
    
   return 0; 
}
