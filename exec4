#include <stdio.h>

int main(){
    int numero[12];
    int pares = 0;
    
    for (int i = 0; i < 12; i++){
        printf("Digite os números para saber os pares ");
        scanf("%d", &numero[i]);
        
        if(numero[i] %2){
            pares++;
        }
    }

    printf("Os números pares foram \n%d", pares);
    
   return 0; 
}
