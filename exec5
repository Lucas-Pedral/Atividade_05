#include <stdio.h>

int main(){
    float numero[6];
    int soma = 0, media;
    
    for (int i = 0; i < 6; i++){
        printf("Digite os núemros para saber a media ");
        scanf("%f", &numero[i]);
        
        soma += numero[i];
        media = soma / 6;
        }

    printf("A media dos numeros foi de \n%d", media);
    
   return 0; 
}
