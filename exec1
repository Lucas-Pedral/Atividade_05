#include <stdio.h>
int main() {
    int numero[10];
    
    for (int i = 0; i < 10; i++){
        printf("Digite o número ");
        scanf("%d", &numero[i]);
    }
    
    printf("Os números digitados foram %d, %d, %d, %d, %d, %d, %d, %d,%d, %d", numero[0], numero[1], numero[2], numero[3], numero[4], numero[5], numero[6], numero[7], numero[8], numero[9], numero[10]);
    return 0;
}
